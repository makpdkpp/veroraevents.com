// เก็บรหัสผ่านเป็น "hash" เท่านั้น (bcrypt/argon2) — ห้ามเก็บเป็น plaintext
// สร้าง hash ได้จากหน้า /admin/change-password.php หลังจากเข้าสู่ระบบ
// หรือสร้างจาก PHP CLI:
//   php -r "echo password_hash('รหัสผ่านของคุณ', PASSWORD_DEFAULT), PHP_EOL;"
define('ADMIN_PASSWORD_HASH', '$2y$10$REPLACE_ME_WITH_A_REAL_HASH_XXXXXXXXXXXXXXXXXXXXXXXXXX');

