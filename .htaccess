RewriteEngine On

# Force blog listing to use PHP (dynamic from _posts)
RewriteRule ^blog/?$ /blog/index.php [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([^/]+)/?$ /blog/post.php?slug=$1 [L,QSA]

# ---- Security: block sensitive files ----------------------------------------
# Dotfiles (.env, .git, .login-fails.json, etc.) and risky file types
<FilesMatch "(^\.|\.(log|md|json|example|bak|ini|yml|yaml)$)">
  Require all denied
</FilesMatch>

# Belt + braces: never serve config.php as a file
<Files "config.php">
  Require all denied
</Files>

# ---- Security headers (public site) -----------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # Public site CSP — allows Google Fonts, Unsplash images, and site inline styles/scripts
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
</IfModule>
